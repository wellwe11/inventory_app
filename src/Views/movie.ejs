<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/movie/movieWrapper.css">
    <link rel="stylesheet" href="/css/movieGenres.css">
    <title>Document</title>
  </head>
  <body>
    <%- include("./partials/nav") %>
    <div class="movieContainer">

        <section class="left_panel">
          <div class="textContent">

            <p class="bio_text minimal_text"><%= title %> - <%= year %></p>
            <p class="bio_text minimal_text">
              <a class="director_link" href="/director?id=<%= director_id %>">
                <%= director_name %>
              </a>
            </p>

            <%- include("./partials/movieGenres", { genre_list }) %>
              
              <div class="a_container">
                <a class="a_el minimal_link_style" href="/editMovie">EDIT</a>
            </div>
          </section>


      <section class="movieWrapper">
        <img class="movieImage" src=<%= src %> alt="">
      </section>
  
    </div>

    
  </body>
</html>

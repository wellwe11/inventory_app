  <!-- vv Script for addMovieForm! vv -->
  <script>
    const dropZone = document.getElementById("drop-zone");
    const preview = document.getElementById("preview");
    const fileInput = document.getElementById("file-input");
    const clearBtn = document.getElementById("clear-btn");

    dropZone.addEventListener("drop", (e) => {
      if ([...e.dataTransfer.item].some((item) => item.kind === "file")) {
        e.preventDefault()
      }
    })

    dropZone.addEventListener("dragover", (e) => {
      const fileItems = [...e.dataTransfer.items].filter((item) => item.kind === "file");
      if (fileItems.length > 0) {
        e.preventDefault();
        if (fileItems.some((item) => item.type.startsWith("image/"))) {
          e.dataTransfer.dropEffect = "copy"
        } else {
          e.dataTransfer.dropEffect = "none"
        }
      }
    })


  window.addEventListener("dragover", (e) => {
    const fileItems = [...e.dataTransfer.items].filter(
      (item) => item.kind === "file",
    );
    if (fileItems.length > 0) {
      e.preventDefault();
      if (!dropZone.contains(e.target)) {
        e.dataTransfer.dropEffect = "none";
      }
    }
  });


function displayImages(files) {
  for (const file of files) {
    if (file.type.startsWith("image/")) {
      const li = document.createElement("li");
      const img = document.createElement("img");
      img.src = URL.createObjectURL(file);
      img.alt = file.name;
      li.appendChild(img);
      li.appendChild(document.createTextNode(file.name));
      preview.appendChild(li)
    }
  }
}

function dropHandler(ev) {
  ev.preventDefault();
  const files = [...ev.dataTransfer.items]
  .map((item) => item.getAsFile())
  .filter((file) => file);
  displayImages(files)
}

fileInput.addEventListener("change", (e) => {
  displayImages(e.target.file);
})

clearBtn.addEventListener("click", () => {
  for (const img of preview.querySelectorAll("img")) {
    URL.revokeObjectURL(img.src);
  }
  preview.textContent = "";
})

  </script>
<!-- ^^ Script for addMovieForm! ^^ -->


<!-- vv Script for filterForm! vv -->
  <script defer>
    const yearMinText = document.querySelector(".yearMinText");
    const yearMaxText = document.querySelector(".yearMaxText");

    const yearMaxInput = document.getElementById("toSlider");
    const yearMinInput = document.getElementById("fromSlider");

    const minPos = {target: 0, current: 0};
    const maxPos = {target: 0, current: 0};
    const speed = 0.2;

    const animate = () => {
        minPos.current += (minPos.target - minPos.current) * speed;
        yearMinText.style.left = `${minPos.current}%`;
        yearMinText.style.transform = `translate(-${minPos.current * 12}%)`

        maxPos.current += (maxPos.target - maxPos.current) * speed;
        yearMaxText.style.left = `${maxPos.current}%`;
        yearMaxText.style.transform = `translate(-${maxPos.current * 12}%)`

        requestAnimationFrame(animate)
    }
    
    animate();

    yearMinInput.addEventListener("input", (e) => {
        minPos.target = e.target.value;
        yearMinText.textContent = e.target.value;
    });

    yearMaxInput.addEventListener("input", (e) => {
        maxPos.target = e.target.value;
        yearMaxText.textContent = e.target.value;
    });

    document.addEventListener("DOMContentLoaded", () => {
        minPos.target = +yearMinInput.value;
        minPos.current = minPos.target;

        maxPos.target = +yearMaxInput.value;
        maxPos.current = maxPos.target;

        yearMinText.textContent = minPos.target;
        yearMaxText.textContent = maxPos.target;
    });
  </script>
  <!-- ^^ Script for filterForm! ^^ -->

</html>

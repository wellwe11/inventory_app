<form action="/" method="POST">
  <div class="sliders_container">
    <label for="year">Years range</label>

    <div class="yearText">
      <p class="yearMinText yearTextP"></p>
      <p class="yearMaxText yearTextP"></p>
    </div>

    <div class="sliders_control">

        <!-- Visual slider-inputs that scale from 0-100 -->
      <input
        type="range"
        id="fromSlider"
        min="0"
        max="100"
        value="0"
        data-min=<%= minYear %>
        data-max=<%= maxYear %>
      />

      <input
        type="range"
        id="toSlider"
        min="0"
        max="100"
        value="100"
        data-min=<%= minYear %>
        data-max=<%= maxYear %>
      />
      

      <!-- Original data which is stale data which I need when reloading page -->
      <input type="hidden" value=<%= minYear %> name="minYear" />
      <input type="hidden" value=<%= maxYear %> name="maxYear" />
      <input type="hidden" value=<%= genres %> name="genres" />

      <!-- The actual years that will be posted -->
      <input
      id="fromHidden"
      class="inputHidden"
      type="hidden"
      name="years"
      value=<%= filteredMinYear || minYear %>
      />
      
      <input
      id="toHidden"
      class="inputHidden"
      type="hidden"
      name="years"
      value=<%= filteredMaxYear || maxYear %>
      />
    </div>
  </div>

  <div>
    <p>Genres</p>
    <%- include("./genres", { genres, checkedGenres }) %>
  </div>

  <button type="submit">Search</button>
</form>

<form action="/" method="POST">
  <div class="sliders_container">
    <label for="year">Years range</label>

    <div class="yearText">
      <p class="yearMinText yearTextP"></p>
      <p class="yearMaxText yearTextP"></p>
    </div>

    <div class="sliders_control">
      <input
        type="range"
        id="fromSlider"
        min="0"
        max="100"
        value="0"
        data-min=<%= minYear %>
        data-max=<%= maxYear %>
      />

      <input
        type="range"
        id="toSlider"
        min="0"
        max="100"
        value="100"
        data-min=<%= minYear %>
        data-max=<%= maxYear %>
      />
      
      <input
      id="fromHidden"
      class="inputHidden"
      type="hidden"
      name="year"
      value=<%= minYear %>
      />
      
      <input
      id="toHidden"
      class="inputHidden"
      type="hidden"
      name="year"
      value=<%= maxYear %>
      />
    </div>
  </div>

  <div>
    <p>Genres</p>
    <%- include("./genres", { genres }) %>
  </div>

  <button type="submit">Search</button>
</form>
